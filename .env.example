# ======================
# Hesap Getir Ortam Değişkenleri
# ======================
# Bu dosyayı kopyalayın: cp .env.example .env
# Sonra .env içindeki değerleri doldurun

# ---- Uygulama ----
NODE_ENV=production
FRONTEND_URL=https://hesapgetir.com

# ---- Veritabanı ----
DB_NAME=hesapgetir
DB_USER=hesap_admin
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ---- Redis ----
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ---- JWT ----
JWT_SECRET=CHANGE_THIS_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_ANOTHER_64_CHAR_RANDOM_STRING

# ---- Iyzico Ödeme ----
IYZICO_API_KEY=your-iyzico-api-key
IYZICO_SECRET_KEY=your-iyzico-secret-key
IYZICO_BASE_URL=https://api.iyzipay.com
# Test için: https://sandbox-api.iyzipay.com

# ---- Yemeksepeti ----
YEMEKSEPETI_API_KEY=
YEMEKSEPETI_SECRET=

# ---- Getir ----
GETIR_API_KEY=

# ---- Trendyol ----
TRENDYOL_API_KEY=
TRENDYOL_SECRET=

# ---- Frontend URLs ----
NEXT_PUBLIC_API_URL=https://hesapgetir.com
NEXT_PUBLIC_WS_URL=https://hesapgetir.com
